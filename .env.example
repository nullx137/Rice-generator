# === API Provider ===
# Доступные значения: openrouter, cometapi
API_PROVIDER=openrouter

# OpenRouter API Key
# Получите ключ на https://openrouter.ai/
OPENROUTER_API_KEY=api_key

# CometAPI Key (альтернатива)
# Получите ключ на https://cometapi.com/
COMETAPI_API_KEY=api_key
COMETAPI_BASE_URL=https://api.cometapi.com/v1

# === Настройки модели ===
RICE_MODEL=google/gemini-3-flash-preview # Для cometapi gemini-3-flash

# === Таймауты и лимиты ===
REQUEST_TIMEOUT=120
MAX_RETRIES=3

# Общие max_tokens (fallback)
MAX_TOKENS=16384

# === Лимиты токенов для генерации ===
# Hyprland — самый сложный конфиг (переменные + binds + rules)
HYPRLAND_MAX_TOKENS=8000

# Waybar — config.json + style.css (два файла)
WAYBAR_MAX_TOKENS=6000

# Kitty — простой конфиг (цвета + шрифт)
KITTY_MAX_TOKENS=3000

# === Лимиты токенов для ИИ-валидации ===
# Анализ конфигов (поиск расхождений)
VALIDATE_ANALYSIS_TOKENS=4000

# Исправление конфигов (максимум для полного ответа)
VALIDATE_FIX_TOKENS=8000

# === Задержки между запросами (секунды) ===
# Помогает избежать rate-limit и экономит ресурсы
REQUEST_DELAY=0

# === Прочее ===
HTTP_REFERER=https://github.com/nullx137/Rice-generator
APP_TITLE=Rice Generator
VERBOSE=false
