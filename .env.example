# OpenRouter API Key
# Получите ключ на https://openrouter.ai/
OPENROUTER_API_KEY=your_api_key_here

# === Настройки модели ===
# Доступные модели:
#   google/gemini-3-flash-preview (рекомендуется)
#   google/gemini-2.0-flash-001
#   anthropic/claude-3.5-sonnet
RICE_MODEL=google/gemini-3-flash-preview

# === Таймауты и лимиты ===
REQUEST_TIMEOUT=120
MAX_RETRIES=3
MAX_TOKENS=16384

# === Прочее ===
HTTP_REFERER=https://github.com/yourusername/rice-generator
APP_TITLE=Rice Generator
VERBOSE=false
