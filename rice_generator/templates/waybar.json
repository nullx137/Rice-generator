{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 4,
  "exclusive": true,
  "passthrough": false,
  "gtk-layer-shell": true,
  
  "modules-left": ["hyprland/workspaces", "tray"],
  "modules-center": ["hyprland/window"],
  "modules-right": ["pulseaudio", "network", "battery", "clock"],
  
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "´äá",
      "2": "´ëę",
      "3": "´ü╝",
      "4": "´äí",
      "5": "´Çü",
      "6": "´äŤ",
      "7": "´éŤ",
      "8": "´äö",
      "9": "´ćś",
      "10": "´Çô",
      "urgent": "´ü¬",
      "focused": "´ćĺ",
      "default": "´äĹ"
    },
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "all-outputs": true,
    "active-only": false,
    "persistent-workspaces": {
      "*": 10
    }
  },
  
  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "separate-outputs": false,
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Firefox": "$1",
      "(.*) - Kitty": "$1"
    }
  },
  
  "tray": {
    "icon-size": 18,
    "spacing": 10,
    "show-passive-items": true
  },
  
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon}´Őö {volume}%",
    "format-bluetooth-muted": "´Üę {icon}´Őö",
    "format-muted": "´Üę",
    "format-icons": {
      "headphone": "´Çą",
      "hands-free": "´ľÉ",
      "headset": "´ľÉ",
      "phone": "´éĽ",
      "portable": "´éĽ",
      "car": "´ć╣",
      "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
    },
    "on-click": "pavucontrol",
    "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "scroll-step": 5
  },
  
  "network": {
    "format": "{ifname}",
    "format-wifi": "´çź {essid} ({signalStrength}%)",
    "format-ethernet": "´×ľ {ifname}",
    "format-disconnected": "Disconnected",
    "tooltip": true,
    "tooltip-format": "{ifname} via {gwaddri}",
    "tooltip-format-wifi": "´çź  {essid} ({signalStrength}%)\nFrequency: {frequency}MHz\nInterface: {ifname}\nIP Address: {ipaddr}",
    "tooltip-format-ethernet": "´×ľ {ifname}\nInterface: {ifname}\nIP Address: {ipaddr}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "nm-connection-editor",
    "on-click-right": "nmcli radio wifi off"
  },
  
  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "´Śž {capacity}%",
    "format-plugged": "´çŽ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"],
    "on-click": "powerprofilesctl",
    "interval": 30
  },
  
  "clock": {
    "format": "{:%H:%M %d.%m.%y}",
    "format-alt": "{:%A, %d %B %Y}",
    "tooltip": true,
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "days": "<span color='#ecc6d9'><b>{}</b></span>",
        "weeks": "<span color='#99ffdd'><b>W{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  
  "custom/media": {
    "format": "{icon} {}",
    "interval": 1,
    "exec": "playerctl metadata --format='{{ artist }} - {{ title }}' 2>/dev/null || echo 'No media'",
    "max-length": 30,
    "format-icons": {
      "Playing": "´ůä",
      "Paused": "´Őő",
      "Stopped": "´ŐŹ"
    }
  }
}
